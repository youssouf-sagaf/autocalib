# Copy to `.env` in this directory and fill in values. Never commit `.env`.

# U-Net APKLOT — local path to the trained .pth checkpoint.
UNET_CHECKPOINT_PATH=artifacts/best_unet_apklot.pth

# Square input resolution fed to the U-Net (must match training, default 256).
# UNET_INPUT_SIZE=256

# Optional: cuda | cpu | mps | auto (default auto: cuda, else mps, else cpu).
# SEGMENTATION_DEVICE=

# YOLO-OBB parking spot detection model (2 classes: empty_slot / occupied_slot).
YOLO_SPOTS_WEIGHTS_PATH=artifacts/parking_spots_best.pt

# Detection thresholds.
# YOLO_CONF_THRESHOLD=0.25
# YOLO_IOU_NMS_THRESHOLD=0.45
# DETECTION_DEVICE=
