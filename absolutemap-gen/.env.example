# Copy to `.env` in this directory and fill in values. Never commit `.env`.

# Image source: "mapbox" (default) or "ign" (IGN Géoplateforme BD ORTHO, free, France only).
# IMAGE_SOURCE=mapbox

# IGN Géoplateforme settings (only used when IMAGE_SOURCE=ign).
# No API key required — the service is freely accessible.
# IGN_LAYER=ORTHOIMAGERY.ORTHOPHOTOS
# IGN_IMAGE_FORMAT=image/jpeg
# IGN_DEFAULT_RADIUS_M=128.0

# SegFormer — Hugging Face model directory (config.json, preprocessor_config.json, weights).
# Default if unset: artifacts/checkpoints/segformer-b0-parkable-best under absolutemap-gen/.
# SEGFORMER_CHECKPOINT_DIR=artifacts/checkpoints/segformer-b0-parkable-best

# Optional: cuda | cpu | mps | auto (default auto: cuda, else mps, else cpu).
# SEGMENTATION_DEVICE=

# YOLO-OBB parking spot detection model (2 classes: empty_slot / occupied_slot).
YOLO_SPOTS_WEIGHTS_PATH=artifacts/parking_spots_best.pt

# Detection thresholds.
# YOLO_CONF_THRESHOLD=0.25
# YOLO_IOU_NMS_THRESHOLD=0.45
# DETECTION_DEVICE=
